# Copy this file to ".env" and fill in your key.
# The .env file is git-ignored and is read by both the local API server
# (server/index.js) and docker compose.

# Your OpenAI API key (used only server-side, never exposed to the browser).
OPENAI_API_KEY=

# Chat model used for hybrid graph enrichment.
OPENAI_MODEL=gpt-4o

# Claude (Anthropic) fallback — used automatically when the OpenAI call above
# is missing or fails. Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Port the enrichment API listens on.
PORT=8787
